# Supabase — Project Settings → API in the Supabase dashboard.
# The anon key is safe to expose to the browser; never commit or expose
# the service_role key (this project doesn't use it at all).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini — used server-side only (app/api/ai/*), never sent to the
# browser. Get a free key at aistudio.google.com/apikey.
GEMINI_API_KEY=
